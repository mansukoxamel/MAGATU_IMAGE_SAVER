{
  "manifest_version": 3,
  "name": "MAGATU Image Saver",
  "version": "0.2.4",
  "description": "Adds a small download button to visible images on any site.",
  "permissions": [
    "downloads",
    "declarativeNetRequest",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "adapters/xchina.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
